# HTTP 入口（80 端口）
# 关键设计：不再使用 upstream 块（开源 nginx 的 upstream server 用 hostname 时只在
# 启动时解析一次 DNS，docker compose 重启后容器 IP 变了，会把请求反代到错误容器）。
# 改用 resolver + 变量 proxy_pass，nginx 每次请求都向 Docker DNS（127.0.0.11）查询
# 当前最新的 service IP。resolver 已在 nginx.conf 的 http 块声明。

server {
    listen 80 default_server;
    server_name ${DOMAIN} _;

    # ACME / Let's Encrypt 验证目录
    location /.well-known/acme-challenge/ {
        root /var/www/acme;
    }

    include /etc/nginx/conf.d/_upstream.inc;
}
