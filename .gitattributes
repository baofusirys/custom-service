# 强制 LF 行尾（部署目标是 Linux 容器，CRLF 会让 .sh / Dockerfile 直接死）
* text=auto eol=lf

# 二进制文件不动
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.tgz binary
*.gz binary

# 显式声明几类必须 LF
*.sh        text eol=lf
Dockerfile  text eol=lf
*.conf      text eol=lf
*.cnf       text eol=lf
*.template  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.go        text eol=lf
*.sql       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.vue       text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.md        text eol=lf
