# ========== custom_service 环境变量模板 ==========
# 用法：cp .env.example .env，然后改下面所有「!! 必改 !!」的项
# ===================================================
#
# ──────── 30 秒生成强密码 ────────
# Linux / Mac 终端复制粘贴这一段，会一次性输出所有需要的随机值：
#   for k in MYSQL_ROOT MYSQL_APP REDIS JWT TURN; do
#     echo "$k=$(openssl rand -hex 32)"
#   done
#   echo "DATA_AES_KEY=$(openssl rand -hex 32)"   # 必须正好 64 hex
#
# Windows PowerShell 等价：
#   1..5 | % { -join ((1..64) | % { '{0:x}' -f (Get-Random -Max 16) }) }
#
# 把上面输出的值依次填进下面的 MYSQL_ROOT_PASSWORD / MYSQL_PASSWORD /
# REDIS_PASSWORD / JWT_SECRET / TURN_STATIC_AUTH_SECRET / DATA_AES_KEY。
#
# ⚠️ 千万别把改好的 .env 提交进 git！.gitignore 默认排除，不要手贱 git add -f。
# ===================================================

# -------- 镜像源（仅「docker-compose.production.yml 拉镜像」部署时相关）--------
# 默认从 GHCR（github 美国）拉。国内服务器拉得慢/拉不下来时，改成阿里云 ACR 等国内源：
#   REGISTRY_BASE=registry.cn-hangzhou.aliyuncs.com/baofusir
# 留空/不设则用默认 ghcr.io/baofusirys。源码 build 部署（docker-compose.yml）用不到此项。
#REGISTRY_BASE=

# -------- 公开域名（必改） --------
PUBLIC_DOMAIN=cs.example.com
# 是否启用 HTTPS（生产必须 true，本地调试可 false）
ENABLE_HTTPS=true
# Let's Encrypt 自动证书申请的邮箱（!! ENABLE_HTTPS=true 时必填 !!）
# 用于证书过期通知；不验证邮箱本身，但必须是合法邮箱格式。
# 留空则只跑 HTTP（acme.sh 不会自动申请证书）。
# 一条 docker compose up -d --build 启动后：
#   - 如果证书不存在 → acme.sh 自动通过 HTTP-01 challenge 申请
#   - 如果证书 < 30 天过期 → 自动续期
#   - 启动 cron，每天 03:00 检查续期
# 前提：DNS 已把 PUBLIC_DOMAIN 解析到本服务器，80 端口未被防火墙挡。
ACME_EMAIL=

# -------- 全局时区（北京时间）--------
TZ=Asia/Shanghai

# -------- MySQL（!! 必改密码 !!） --------
MYSQL_ROOT_PASSWORD=please-change-this-strong-password
MYSQL_DATABASE=custom_service
MYSQL_USER=cs_app
MYSQL_PASSWORD=please-change-this-app-password

# -------- Redis（!! 必改密码 !!） --------
REDIS_PASSWORD=please-change-this-redis-password

# -------- JWT 密钥（!! 必改，建议 openssl rand -hex 32 !!） --------
JWT_SECRET=please-change-to-64-hex-chars-random-string

# -------- AES-GCM 数据加密密钥（!! 必改，必须 64 个十六进制字符 = 32 字节 !!） --------
DATA_AES_KEY=please-change-to-exactly-64-hex-chars-aes-256-key-must-be-64hex

# -------- 首次启动的超管账号（首次登录后必须改密） --------
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=please-change-this-bootstrap-password

# -------- 后端服务参数 --------
BACKEND_HTTP_PORT=8080
BACKEND_LOG_LEVEL=info
BACKEND_MAX_UPLOAD_MB=20
# [062] 所有按 IP 的限流已移除（集成方 NAT 后多设备同 IP 误封代价过高，爷爷决策）
# 仅保留按访客 session 的消息限流（per-visitor，跟 IP 无关，不会因 NAT 误封）
# 单访客每分钟消息条数 — 0 = 不限制；20 = 单访客 1 秒 ~ 0.3 条速率，正常打字够用
SECURITY_VISITOR_MSG_PM=20

# -------- 数据持久化目录（宿主机绝对路径，必须在仓库外） --------
HOST_DATA_DIR=/srv/cs-data

# -------- 对外端口（避免跟集成方服务器已有服务冲突）[044] --------
# 80/443 是最常见冲突项：服务器已经跑了别的 nginx/apache/caddy 就改这里。
# 改之后，访问 URL 要带端口：https://yourdomain:8443  访客 widget 集成代码同样改。
# 不冲突就保持默认。
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -------- CoTURN（WebRTC TURN/STUN 中继，VPN/严格 NAT 下保证通话能通） --------
# 服务器公网 IP（!! 必填 !!，否则 srflx 报内网地址 P2P 打洞失败）
TURN_EXTERNAL_IP=1.2.3.4
# TURN realm，通常等于 PUBLIC_DOMAIN
TURN_REALM=cs.example.com
# 短期凭证 HMAC 密钥（!! 必改，建议 openssl rand -hex 32 !!）
# 后端 /api/turn-credential 用同一个 secret 计算 password，CoTURN 用同一个 secret 校验
# 泄露后任何人都能用我们的 TURN 中继流量，必须保密
TURN_STATIC_AUTH_SECRET=please-change-to-64-hex-chars-random-string

# [044] TURN 端口（避免冲突；默认值经过精挑选，一般不用改）
# 3478 = TURN STUN 标准端口
# 5349 = TURN over TLS 标准端口
TURN_LISTEN_PORT=3478
TURN_TLS_PORT=5349
# UDP relay 端口范围（媒体流走这里；20 个端口 ≈ 20 路并发通话）
# 默认 50000-50200 避开 Linux ephemeral 32768-60999 的常用前段
# 注：在云厂商安全组 + 服务器防火墙都要开放这个 UDP 范围
TURN_MIN_PORT=50000
TURN_MAX_PORT=50200
