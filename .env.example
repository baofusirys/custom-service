# ========== custom_service 环境变量模板 ==========
# 用法：cp .env.example .env，然后改下面所有「!! 必改 !!」的项
# ===================================================

# -------- 公开域名（必改） --------
PUBLIC_DOMAIN=cs.example.com
# 是否启用 HTTPS（生产必须 true，本地调试可 false）
ENABLE_HTTPS=true

# -------- 全局时区（北京时间）--------
TZ=Asia/Shanghai

# -------- MySQL（!! 必改密码 !!） --------
MYSQL_ROOT_PASSWORD=please-change-this-strong-password
MYSQL_DATABASE=custom_service
MYSQL_USER=cs_app
MYSQL_PASSWORD=please-change-this-app-password

# -------- Redis（!! 必改密码 !!） --------
REDIS_PASSWORD=please-change-this-redis-password

# -------- JWT 密钥（!! 必改，建议 openssl rand -hex 32 !!） --------
JWT_SECRET=please-change-to-64-hex-chars-random-string

# -------- AES-GCM 数据加密密钥（!! 必改，必须 64 个十六进制字符 = 32 字节 !!） --------
DATA_AES_KEY=please-change-to-exactly-64-hex-chars-aes-256-key-must-be-64hex

# -------- 首次启动的超管账号（首次登录后必须改密） --------
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=please-change-this-bootstrap-password

# -------- 后端服务参数 --------
BACKEND_HTTP_PORT=8080
BACKEND_LOG_LEVEL=info
BACKEND_MAX_UPLOAD_MB=20
# 单 IP HTTP 限流（每分钟）
SECURITY_IP_HTTP_RPM=60
# 单 IP 每分钟 WSS 握手次数
SECURITY_IP_WS_HANDSHAKE_PM=5
# 单访客每分钟消息条数
SECURITY_VISITOR_MSG_PM=10
# 单 IP 24 小时内被拦截多少次后拉黑
SECURITY_IP_BLACKLIST_THRESHOLD=200

# -------- 数据持久化目录（宿主机绝对路径，必须在仓库外） --------
HOST_DATA_DIR=/srv/cs-data
